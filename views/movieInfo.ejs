<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" href="images/mbLogo.png">
  <title>MockBusters</title>
  <link rel="stylesheet" href="/styles/styles.css">
</head>


  <body>
  <%- include ('../views/partials/header.ejs') %>

    <main>
      <div id="movieInfo-grid">
        <section id="selected-movie-section">
            <img src=<%= `${movie.movieCover}` %> id="movie-info-cover-img" alt="MockBusters logo image">
            <h3><%= movie.movieName %></h3>
            <p><%= movie.movieAdvancedInfo %></p>
            <p><strong>Genre: </strong> <%= movie.movieGenre %></p>
            <p><strong>Rated: </strong><%= movie.movieRating %> </p>
            <p><strong>reviews: </strong><%= movie.movieReview %> </p>
        </section>
        <a id="movieInfo-rent-a" href="/billing">RENT MOVIE</a>
        <button onclick="addCart(<%= index %>)">add to cart</button>
        <button onclick="clearCart()">clear cart</button>
        <a  href="/cart">view cart</a>
      </div>
    </main>
  </body>
</html>

<script>
  function addCart(index){
    if(!localStorage.getItem("cart")){
      localStorage.setItem("cart", JSON.stringify([]));
    }

    let cart = JSON.parse(localStorage.getItem("cart")) || [];

    //prevent adding duplicate movies
    if(!cart.includes(index)){
      cart.push(index);
    }
    else{
      return;
    }

    localStorage.setItem("cart", JSON.stringify(cart));
    alert(cart);
  }

  function clearCart(){
    localStorage.setItem("cart", JSON.stringify([]));
    alert("Cart cleared!");
  }
</script> 