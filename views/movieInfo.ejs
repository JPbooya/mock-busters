<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Favicon -->
  <link rel="icon" href="images/mbLogo.png">
  <title>MockBusters</title>
  <!-- Styles -->
  <link rel="stylesheet" href="/styles/styles.css">
</head>


<body>
<%- include ('../views/partials/header.ejs') %>


  <main>
  <section id="movies-section">
    <% moviesData.forEach(movie => { %>
      <div >
        <h3><%= movie.movieName %></h3>
        <p><%= movie.movieInfo %></p>
        <p>Genre: <%= movie.movieGenre %></p>
        <p>selected: <%= movie.selected %></p>
      </div>
    <% }) %>
  </section>
  </main>

  <footer>
    <a href="https://github.com/JPbooya/mock-busters">GIT LINK</a>
  </footer>

</body>
</html>