<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin</title>
  <!-- Scripts -->
  <script src="//code.jquery.com/jquery-3.7.1.js"></script>
  <script src="//cdn.datatables.net/2.3.7/js/dataTables.js"></script>
  <!-- Styles -->
  <link href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.css" rel="stylesheet">
</head>

<!--   
const order = {
    firstName: req.body.fname,
    lastName: req.body.lname,
    address: req.body.aname,
    city: req.body.cname,
    state: req.body.sname,
    zipcode: req.body.zname,
    creditcard: req.body["credit-card-name"],
    expiration: req.body.exname,
    extension: req.body["expiration-name"],
    delivery: req.body.delivery,
    timestamp: new Date()
  } 
-->

<body>
  <table id="order-table" class="display">
    <thead>
      <tr>
        <th>Name</th>
        <th>Address</th>
        <th>City</th>
        <th>State</th>
        <th>ZipCode</th>
        <th>CreditCard</th>
        <th>Expiration</th>
        <th>Extension</th>
        <th>Timestamp</th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(order => {%>
      <tr>
        <td><%=order.firstName%> <%=order.lastName%></td>
        <td><%=order.address%></td>
        <td><%=order.city%></td>
        <td><%=order.state%></td>
        <td><%=order.zipcode%></td>
        <td><%=order.creditcard%></td>
        <td><%=order.extension%></td>
        <td><%=order.expiration%></td>
        <td><%=order.timestamp.toLocaleString()%></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <script defer>
    let table = new DataTable('#order-table');
  </script>
</body>

</html>