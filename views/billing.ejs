<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Favicon -->
  <link rel="icon" href="images/mbLogo.png">
  <title>Billing</title>
  <!-- Styles -->
  <link rel="stylesheet" href="/styles/styles.css">
  <!-- Scripts -->
  <script defer src="js/billing.js"></script>
</head>

<body>

  <%- include ('../views/partials/header.ejs') %>
  
  <form id="billing-form" action="/submit" method="post" class="form-grid">

    <div id="rented-movie"><%- include ('../views/partials/movieCard.ejs', {movie, index}) %></div>

    <div>
      <label for="fname">First Name<span class="err" id="err-fname">Invalid First Name.</span></label>
      <input type="text" id="fname" name="fname">
    </div>

    <div>
      <label for="lname">Last Name<span class="err" id="err-lname">Invalid Last Name.</span></label>
      <input type="text" id="lname" name="lname">
    </div>

    <div>
      <label for="email">Email<span class="err" id="err-aname">Invalid email.</span></label>
      <input type="email" id="email" name="email">
    </div>

    <div>
      <label for="cname">City<span class="err" id="err-cname">Invalid City.</span></label>
      <input type="text" id="cname" name="cname">
    </div>

    <div>
      <label for="sname">State<span class="err" id="err-sname">Invalid State.</span></label>
      <input type="text" id="sname" name="sname">
    </div>

    <div>
      <label for="zname">Zip Code<span class="err" id="err-zname">Invalid Zip Code.</span></label>
      <input type="number" id="zname" name="zname">
    </div>

    <!-- Billing Section -->
    <div class="billing-info">
     
      </div>

      <div>
       
      </div>

      <div>
        
      </div>

      <div>
        <label for="dtd-name">Deliver To Door<span class="err" id="err-delivery"></span></label>
        <input type="checkbox" id="dtd-name" name="dtd-name">
      </div>

      <div class="full-width">
        <button type="submit" id="order-button" class="submit-btn">Submit</button>
      </div>
    </div>

  </form>
</body>

</html>